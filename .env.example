# Copy this file to `.env` and fill in values for local development.
# `.env` is gitignored. In CI/production these come from GitHub Secrets.

# Runtime
NODE_ENV=development

# App
APP_NAME=azores
PORT=3000
PUBLIC_URL=http://localhost:3000

# API
API_BASE_URL=http://localhost:3001
API_KEY=replace-me-locally

# Build / deploy
# Public path for the bundled web app. Used by rspack `output.publicPath`.
# Locally leave as "/". On GitHub Pages set to "/<repo-name>/" (set via the
# Pages workflow / repo secret, not committed).
PAGES_BASE=/
